# Пример конфига для второго сайта, работающего параллельно.
# 1. Замени server_name на свой домен/поддомен.
# 2. Укажи порт или имя контейнера второго сайта.
# 3. Переименуй файл в second-site.conf и перезапусти nginx: docker compose restart nginx

server {
    listen 80;
    server_name second-site.local;

    location / {
        proxy_pass http://second-site:4000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
    }
}
